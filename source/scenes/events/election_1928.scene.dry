    <!-- OWP -->
    [? if owp_in_government and owp_r > 0 :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#954B00'></div> OWP:</td>
        <td> [+ owp_r +] </td>
        <td> [+ owp_seat_percentage +]% </td>
        <td> [+ owp_vote_percentage +]% </td>
        <td> [+ str_change_owp +] </td>
    </tr>
    ?]

    <!-- National Minorities Section -->
    <tr>
        <td colspan="5"><strong>National Minorities</strong></td>
    </tr>
    <tr>
        <td><strong>Party</strong></td>
        <td><strong>Seats (Sejm)</strong></td>
        <td><strong>% of Seats</strong></td>
        <td><strong>% of Votes</strong></td>
        <td><strong>Change</strong></td>
    </tr>

    <!-- SelRob -->
