title: Sejm Elections
new-page: true
tags: event
priority: -1
view-if: (year = next_election_year and month >= next_election_month) or (year > next_election_year)
on-departure: month_actions += 1; in_election = 0; next_election_year = next_election_year + 4; n_elections += 1; next_election_time = time + 48; speaker_election_1928_time = 1
set-jump: post_election_1928

# the low priority means that this event is only seen after all other events are resolved for the month.

= Elections, [+ month : month +] [+ year +]

The Parliament elections are to be held now.

- @election_algorithm: May we do our best...
- @cancel_elections

@cancel_elections
title: We cannot hold the elections now. Cancel the elections.
subtitle: This is an anti-democratic move that may backfire.
view-if: in_emergency_government == 1 and president == "Braun" and not presidential_powers

Since we are currently ruling as part of an emergency government, we may use quasi-constitutional trickery to significantly delay these elections, and continue governing via Article 48. This is likely to be extremely unpopular both with our base and with the other parties. However, this may be necessary to prevent the extremists from gaining power.

- @cancel_elections_2: Yes, do it.
- @election_algorithm: No, let's hold the elections.

@cancel_elections_2
on-departure: next_election_year = next_election_year + 1; next_election_time = time + 12; pro_republic -= 10; pslp_relation -= 8; pschd_relation -= 8; pslw_relation -= 10; kpp_relation -= 8; political_crisis_level += 2; robotnicy_bbwr -= 4; klasa_srednia_bbwr -= 5; klasa_wyzsza_bbwr -= 5; chlopi_bbwr -= 5; mniejszosci_bbwr -= 5; bezrobotni_bbwr -= 5; political_crisis_level += 2 if owp_normalized >= 0.3; political_crisis_level += 2 if owp_normalized + sn_normalized >= 0.5
achievement: ausnahmezustand

Fine. President [+ president +] has taken the unprecedented step of canceling these elections. New elections are scheduled for [+ next_election_month : month +] [+ next_election_year +].

Let us hope this does not backfire.

@post_election_1928
on-arrival: {!
    // Set the total number of seats in the Sejm (example: 444 total seats)
    var total_seats = 444; 

    // Initialize storage for party quotients and seat allocation
    var party_quotients = [];
    var seat_allocation = {};

    // Initialize total votes
    var total_votes = 0;

    // Define Jewish parties and set the percentage threshold for representation
    var jewish_parties = ['jewish_nationalists', 'jewish_left', 'jewish_conservatives'];
    var representation_threshold = 0.05;  // 5% of total votes required to receive seats

    // Step 1: Calculate total national votes for each party
    for (var party of Q.parties) {
        Q[party + '_national_votes'] = 0;  // Initialize national vote count for each party

        // Aggregate votes for each party across all social classes
        for (var c of Q.classes) {
            Q[party + '_national_votes'] += Q[c] * Q[c + '_' + party + '_normalized'];
        }

        // Track total votes cast nationally
        total_votes += Q[party + '_national_votes'];

        // Initialize seat allocation for each party
        seat_allocation[party] = 0;
    }

    // Step 1.1: Calculate the vote percentage for each party based on total_votes (before fraud)
    if (total_votes > 0) {  // Avoid division by zero
        for (var party of Q.parties) {
            Q[party + '_vote_percentage_before_fraud'] = Math.round((Q[party + '_national_votes'] / total_votes) * 1000) / 10;
        }
    } else {
        // If total_votes is zero, set each party's vote percentage to zero
        for (var party of Q.parties) {
            Q[party + '_vote_percentage_before_fraud'] = 0;
        }
    }

    // Calculate the actual vote threshold based on total votes
    var vote_threshold = total_votes * representation_threshold;

    // Step 1.5: Apply election fraud to move votes from specific minority parties to BBWR
    var fraud_votes = 0;  // Total fraud votes to transfer to BBWR

    // Ensure Q.election_fraud is defined and set its default if not
    Q.election_fraud = Q.election_fraud || 0.2;  // Default fraud level to 20% if not set

    // Explicitly define minority parties by name
    var minority_parties = ['undo_center', 'undo_right', 'belarusians', 'german_right'];

    // Calculate fraud adjustment by summing votes from each minority party
    for (var party of minority_parties) {
        var party_votes = Q[party + '_national_votes'];
        fraud_votes += party_votes * Q.election_fraud;  // Add fraction of votes to fraud adjustment
        Q[party + '_national_votes'] -= party_votes * Q.election_fraud;  // Reduce minority party votes
    }

    // Increase BBWR's vote count by the fraud adjustment
    Q["bbwr_national_votes"] += fraud_votes;

    // Step 1.6: Reapply the threshold check after the fraud adjustment
    for (var party of jewish_parties) {
        // Check if the Jewish party still passes the threshold post-fraud
        if (Q[party + '_national_votes'] >= vote_threshold) {
            Q[party + '_threshold_passed'] = true;  // Ensure this party is eligible
        } else {
            Q[party + '_threshold_failed'] = true;  // Flag for display if needed
        }
    }

    // Step 1.7: Calculate the vote percentage for each party based on total_votes (after fraud)
    if (total_votes > 0) {  // Avoid division by zero
        for (var party of Q.parties) {
            Q[party + '_vote_percentage'] = Math.round((Q[party + '_national_votes'] / total_votes) * 1000) / 10;
        }
    } else {
        // If total_votes is zero, set each party's vote percentage to zero
        for (var party of Q.parties) {
            Q[party + '_vote_percentage'] = 0;
        }
    }

    // Step 2: Apply modified D'Hondt method to calculate quotients for each party that passes the adjusted threshold
    for (var party of Q.parties) {
        var party_votes = Q[party + '_national_votes'];  // Get national votes for this party

        // Only include parties that pass the threshold in seat allocation calculations
        if ((Q[party + '_threshold_passed'] || !jewish_parties.includes(party)) && party_votes > 0) {
            // Boost BBWR quotient by 20% to reflect state-backed influence
            var quotient_boost = (party === 'bbwr') ? 1.2 : 1.0;

            // Calculate quotients for each divisor (1, 2, 3, ..., total seats)
            for (var i = 1; i <= total_seats; i++) {
                var quotient = (party_votes / i) * quotient_boost;  // Calculate boosted quotient
                party_quotients.push({ party: party, quotient: quotient });  // Store party and quotient
            }
        }
    }

    // Step 3: Sort quotients in descending order (highest quotients first)
    party_quotients.sort(function(a, b) {
        if (b.quotient === a.quotient) {
            return a.party === 'bbwr' ? -1 : 1;  // Favor BBWR in case of ties
        }
        return b.quotient - a.quotient;  // Sort from highest to lowest
    });

    // Step 4: Allocate seats based on the highest quotients
    for (var i = 0; i < total_seats; i++) {
        var winning_party = party_quotients[i].party;  // Find the party with the highest remaining quotient
        seat_allocation[winning_party] += 1;  // Assign a seat to this party
    }

    // Step 5: Assign final seat counts to the _r variable for each party (Sejm seats)
    for (var party of Q.parties) {
        Q['old_' + party + '_r'] = Q[party + '_r'] || 0;  // Save old seat allocation for comparison
        Q[party + '_r'] = seat_allocation[party];  // Store the final seat allocation in _r

        // Step 6: Calculate the change in seats (compared to old results)
        Q['change_' + party + '_r'] = Q[party + '_r'] - Q['old_' + party + '_r'];  // Calculate seat change
        var sign = Q['change_' + party + '_r'] > 0 ? '+' : '';
        Q['str_change_' + party] = sign + Q['change_' + party + '_r'];  // Store the string change for display

        // Step 7: Calculate and store the percentage of seats for each party
        if (total_seats > 0) {  // Ensure we are not dividing by zero
            Q[party + '_seat_percentage'] = Math.round((Q[party + '_r'] / total_seats) * 1000) / 10;  // Rounded to 1 decimal
        } else {
            Q[party + '_seat_percentage'] = 0;  // Set to zero if total_seats is zero to avoid NaN
        }
    }

// get change arrows and signs


// The largest party can only be the OWP or the BBWR.
Q.largest_party = 'BBWR';
if (Q.owp_r >= Q.bbwr_r && Q.owp_r >= Q.kpp_r) {
    Q.largest_party = 'OWP';
}
if (Q.kpp_r >= Q.bbwr_r && Q.kpp_r >= Q.owp_r) {
    Q.largest_party = 'KPP';
}

// coalitions
Q.bbwr_majority = Q.bbwr_r;
Q.bbwr_minority = Q.bbwr_r;
Q.patriotic_left_coalition = Q.bbwr_r + Q.pps_r + Q.sch_r + Q.pslw_r;
Q.democratic_left_coalition = Q.pps_r + Q.sch_r + Q.pslw_r;
Q.centre_left_coalition = Q.pps_r + Q.sch_r + Q.pslw_r + Q.npr_r + Q.pschd_r + Q.pslp_r;
Q.centre_right_coalition = Q.npr_r + Q.pschd_r + Q.pslp_r + Q.sn_r;
Q.right_coalition =  Q.pschd_r + Q.pslp_r + Q.sn_r + Q.owp_r;
Q.far_right_coalition = Q.sn_r + Q.owp_r;
Q.left_coalition = Q.pps_r + Q.sch_r + Q.kpp_r;
Q.popular_front_coalition = Q.pps_r + Q.sch_r + Q.pslw_r + Q.kpp_r;

// this is an absurd concept lol
Q.anti_democratic_coalition = Q.sn_r + Q.owp_r + Q.kpp_r;

// Progressive coalition isn't going to be implemented as a distinct coalition but it's the coalition that lets you pass improved women's rights/gay rights
Q.progressive_coalition = Q.pps_r + Q.sch_r + Q.pslw_r;
Q.leverage = Q.bbwr_r;

Q.centre_left_coalition_failed = 0;
// Reset government and ministers... Based on Brüning's 1930 govt
Q.coalition_dissent = 0;
Q.kpp_coalition_dissent = 0;
Q.bbwr_in_government = 1;
Q.in_democratic_left_coalition = 0;
Q.in_centre_left_coalition = 0;
Q.in_left_front = 0;
Q.in_popular_front = 0;
Q.in_emergency_government = 0;
Q.in_minority_government = 0;
Q.in_unity_government = 0;
Q.bbwr_toleration = 0;
Q.bbwr_caretaker = 0;
Q.foreign_minister_party = 'BBWR';
Q.interior_minister_party = 'BBWR';
Q.justice_minister_party = 'BBWR';
Q.labor_minister_party = 'BBWR';
Q.army_minister_party = 'BBWR';
Q.economic_minister_party = 'BBWR';
Q.finance_minister_party = 'BBWR';
Q.agriculture_minister_party = 'BBWR';

// reset KPP goals
Q.kpp_goals_seen = 0;
Q.kpp_ultimatum_seen = 0;
Q.welfare_goal = 0;
Q.agriculture_goal = 0;
Q.economy_goal = 0;
Q.finance_goal = 0;
Q.labor_goal = 0;
Q.foreign_goal = 0;
Q.interior_goal = 0;
Q.reichswehr_goal = 0;

Q.welfare_goal_completed = 0;
Q.agriculture_goal_completed = 0;
Q.economy_goal_completed = 0;
Q.finance_goal_completed = 0;
Q.labor_goal_completed = 0;
Q.foreign_goal_completed = 0;
Q.interior_goal_completed = 0;
Q.reichswehr_goal_completed = 0;

Q.undo_sum = Q.undo_center_r + Q.undo_right_r;
Q.str_change_undo_sum = parseFloat(Q.str_change_undo_center) + parseFloat(Q.str_change_undo_right);

Q.belarusians_sum = Q.belarusian_left_r + Q.belarusian_right_r;
Q.str_change_belarusian_sum = parseFloat(Q.str_change_belarusian_left) + parseFloat(Q.str_change_belarusian_right);

Q.minorities_r_sum = Q.undo_center_r + Q.undo_right_r + Q.belarusian_left_r + Q.belarusian_right_r + Q.jewish_nationalists_r + Q.jewish_conservatives_r + Q.jewish_left_r + Q.german_left_r + Q.german_right_r + Q.solrad_r + Q.selrob_r;
Q.str_change_minorities_sum = parseFloat(Q.str_change_undo_center) + parseFloat(Q.str_change_undo_right) + parseFloat(Q.str_change_belarusian_left_r) + parseFloat(Q.str_change_belarusian_right_r) + parseFloat(Q.str_change_jewish_nationalists_r) + parseFloat(Q.str_change_jewish_conservatives_r) + parseFloat(Q.str_change_jewish_left_r) + parseFloat(Q.str_change_german_left_r) + parseFloat(Q.str_change_german_right_r) + parseFloat(Q.str_change_solrad_r) + parseFloat(Q.str_change_selrob_r);

var election_result = {'date': new Date(Q.year, Q.month - 1)};
for (var party of Q.parties) {
    election_result[party] = Q[party + '_r'];
}
Q.election_records.push(election_result);

Q.government_changed = true;

if (Q.government_changed) {
    updateVotes();
    Q.government_changed = false; // Reset the flag
}

!}
on-departure: centrolew_urgency = 1 if (centrolew_urgency == 0 and owp_r >= 15)
on-display: {!
data = [
    {
        "id": "kpp",
        "legend": "KPP",
        "name": "KPP",
        "seats": Math.round(Q.kpp_r),
    },
    {
        "id": "pps",
        "legend": "PPS",
        "name": "PPS",
        "seats": Math.round(Q.pps_r),
    },
];

if (Q.sl_formed && Q.sl_r) {
    data.push({
            "id": "sl",
            "legend": "SL",
            "name": "SL",
            "seats": Math.round(Q.sl_r),
        });
}
if (!Q.sl_formed || Q.sl_sch_split) {
    data.push({
            "id": "sch",
            "legend": "SCh",
            "name": "SCh",
            "seats": Math.round(Q.sch_r),
        });
}
if (!Q.sl_formed || Q.sl_pslw_split) {
    data.push({
            "id": "pslw",
            "legend": "PSL-W",
            "name": "PSL-W",
            "seats": Math.round(Q.pslw_r),
        });
}
if (!Q.sl_formed || Q.sl_pslp_split) {
    data.push({
        "id": "pslp",
        "legend": "PSL-P",
        "name": "PSL-P",
        "seats": Math.round(Q.pslp_r),
    });
}

data = data.concat([
    {
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.minorities_r_sum),
    },
    {
        "id": "bbwr",
        "legend": "BBWR",
        "name": "BBWR",
        "seats": Math.round(Q.bbwr_r),
    },
    {
        "id": "npr",
        "legend": "NPR",
        "name": "NPR",
        "seats": Math.round(Q.npr_r),
    },
    {
        "id": "pschd",
        "legend": "PSCHD",
        "name": "PSCHD",
        "seats": Math.round(Q.pschd_r),
    },
    {
        "id": "sn",
        "legend": "sn_party_name",
        "name": "sn_party_name",
        "seats": Math.round(Q.sn_r),
    },
    {
        "id": "owp",
        "legend": "OWP",
        "name": "OWP",
        "seats": Math.round(Q.owp_r),
    },
]);

if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}
go-to: coalition_menu

**Election results:**

{!<svg id="reichstag" style="width: 500px; height: 250px;"> </svg>!}

<table style="width: 100%; text-align: center;">
    <!-- Government Section -->
    <tr>
        <td colspan="5"><strong>Government</strong></td>
    </tr>
    <tr>
        <td><strong>Party</strong></td>
        <td><strong>Seats (Sejm)</strong></td>
        <td><strong>% of Seats</strong></td>
        <td><strong>% of Votes</strong></td>
        <td><strong>Change</strong></td>
    </tr>

    <!-- KPP -->
    [? if kpp_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#AF0000'></div> KPP:</td>
        <td> [+ kpp_r +] </td>
        <td> [+ kpp_seat_percentage +]% </td>
        <td> [+ kpp_vote_percentage +]% </td>
        <td> [+ str_change_kpp +] </td>
    </tr>
    ?]

    <!-- PPS -->
    [? if pps_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#CC0000'></div> PPS:</td>
        <td> [+ pps_r +] </td>
        <td> [+ pps_seat_percentage +]% </td>
        <td> [+ pps_vote_percentage +]% </td>
        <td> [+ str_change_pps +] </td>
    </tr>
    ?]

    <!-- SCh -->
    [? if (not sl_formed or sl_sch_split) and sch_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#556B2F'></div> SCh:</td>
        <td> [+ sch_r +] </td>
        <td> [+ sch_seat_percentage +]% </td>
        <td> [+ sch_vote_percentage +]% </td>
        <td> [+ str_change_sch +] </td>
    </tr>
    ?]

    <!-- PSL-W -->
    [? if (not sl_formed or sl_pslw_split) and pslsw_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#179900'></div> PSL-W:</td>
        <td> [+ pslw_r +] </td>
        <td> [+ pslw_seat_percentage +]% </td>
        <td> [+ pslw_vote_percentage +]% </td>
        <td> [+ str_change_pslw +] </td>
    </tr>
    ?]

    <!-- SL -->
    [? if sl_formed and sl_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#3A6538'></div> SL:</td>
        <td> [+ sl_r +] </td>
        <td> [+ sl_seat_percentage +]% </td>
        <td> [+ sl_vote_percentage +]% </td>
        <td> [+ str_change_sl +] </td>
    </tr>
    ?]

    <!-- BBWR -->
    [? if bbwr_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#808080; outline: 2px solid;'></div> <strong>BBWR:</strong></td>
        <td><strong>[+ bbwr_r +]</strong></td>
        <td><strong>[+ bbwr_seat_percentage +]%</strong></td>
        <td><strong>[+ bbwr_vote_percentage +]%</strong></td>
        <td><strong>[+ str_change_bbwr +]</strong></td>
    </tr>
    ?]

    <!-- NPR -->
    [? if npr_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#841839'></div> NPR:</td>
        <td> [+ npr_r +] </td>
        <td> [+ npr_seat_percentage +]% </td>
        <td> [+ npr_vote_percentage +]% </td>
        <td> [+ str_change_npr +] </td>
    </tr>
    ?]

    <!-- PSCHD -->
    [? if pschd_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#1E90FF'></div> PSCHD:</td>
        <td> [+ pschd_r +] </td>
        <td> [+ pschd_seat_percentage +]% </td>
        <td> [+ pschd_vote_percentage +]% </td>
        <td> [+ str_change_pschd +] </td>
    </tr>
    ?]

    <!-- PSL-P -->
    [? if (not sl_formed or sl_pslp_split) and pslp_in_government :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#3A6538'></div> PSL-W:</td>
        <td> [+ pslp_r +] </td>
        <td> [+ pslp_seat_percentage +]% </td>
        <td> [+ pslp_vote_percentage +]% </td>
        <td> [+ str_change_pslw +] </td>
    </tr>
    ?]

    <!-- SN -->
