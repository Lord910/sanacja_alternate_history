        <td> [+ minorities_r_sum  +] </td>
        <td> [+ minorities_seat_percentage +]% </td>
        <td> [+ minorities_vote_percentage +]% </td>
        <td> [+ str_change_minorities_sum +] </td>
    </tr>

    <!-- SelRob -->
