    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#AF0000'></div> SelRob:</td>
        <td> [+ selrob_r +] </td>
        <td> [+ selrob_seat_percentage +]% </td>
        <td> [+ selrob_vote_percentage +]% </td>
        <td> [+ str_change_selrob +] </td>
    </tr>
    ?]

    <!-- SolRad -->
    [? if solrad_r > 0 :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#CC0000'></div> SolRad:</td>
        <td> [+ solrad_r +] </td>
        <td> [+ solrad_seat_percentage +]% </td>
        <td> [+ solrad_vote_percentage +]% </td>
        <td> [+ str_change_solrad +] </td>
    </tr>
    ?]

    <!-- UNDO -->
