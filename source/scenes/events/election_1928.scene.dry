        <td style="text-align: left;"><div class="box" style='background-color:#556B2F'></div> SCh:</td>
        <td> [+ sch_r +] </td>
        <td> [+ sch_seat_percentage +]% </td>
        <td> [+ sch_vote_percentage +]% </td>
        <td> [+ str_change_sch +] </td>
    </tr>
    ?]

