    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#4682B4'></div> UNDO:</td>
        <td> [+ undo_sum +] </td>
        <td> [+ undo_seat_percentage +]% </td>
        <td> [+ undo_vote_percentage +]% </td>
        <td> [+ str_change_undo_sum +] </td>
    </tr>
    ?]

    <!-- Jewish Left -->
    [? if not jewish_left_r > 0 :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#1E90FF'></div> Jewish Left:</td>
        <td> [+ jewish_left_r +] </td>
        <td> [+ jewish_left_seat_percentage +]% </td>
        <td> [+ jewish_left_vote_percentage +]% </td>
        <td> [+ str_change_jewish_left +] </td>
    </tr>
    ?]

    <!-- Jewish Nationalists -->
    [? if jewish_nationalists_r > 0 :
    <tr>
        <td style="text-align: left;"><div class="box" style='background-color:#1E90FF'></div> Jewish Nationalists:</td>
        <td> [+ jewish_nationalists_r +] </td>
        <td> [+ jewish_nationalists_seat_percentage +]% </td>
        <td> [+ jewish_nationalists_vote_percentage +]% </td>
        <td> [+ str_change_jewish_nationalists +] </td>
    </tr>
    ?]

    <!-- Jewish Conservatives -->
