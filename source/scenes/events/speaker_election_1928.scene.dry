@post_election
on-arrival: {!
Q.bbwr_speaker_votes = 0;
Q.pps_speaker_votes = 0;
Q.sn_speaker_votes = 0;
Q.minorities_speaker_votes = 0;
Q.kpp_speaker_votes = 0;
Q.empty_speaker_votes = 0;

// initial phase:
Q.pps_speaker_votes += Q.pps_r;
Q.sn_speaker_votes += Q.sn_r;
Q.sn_speaker_votes += Q.owp_r;
Q.kpp_speaker_votes += Q.kpp_r;


if (Q.bbwr_speaker_campaign) {
    Q.bbwr_speaker_votes += Q.bbwr_r;
    if (Q.pps_support_bbwr) {
        Q.pps_speaker_votes -= Q.pps_r;
        Q.bbwr_speaker_votes += Q.pps_r;
        Q.bbwr_speaker_votes += Q.sch_r;
        Q.bbwr_speaker_votes += Q.pslw_r;
        Q.bbwr_speaker_votes += Q.other_r;
        Q.sn_speaker_votes += Q.pschd_votes;
        Q.sn_speaker_votes += Q.npr_votes;
        Q.sn_speaker_votes += Q.pslp_votes;      
    } else {
        Q.pps_speaker_votes += Q.pslw_r;
        Q.pps_speaker_votes += Q.sch_r;
    }
    if (Q.other_support_bbwr) {
        Q.minorities_speaker_votes -= Q.other_r;
        Q.bbwr_speaker_votes += Q.other_r;
    } else {
        Q.empty_speaker_votes += Q.npr_r;
    }
    if (Q.npr_support_bbwr) {
        Q.bbwr_speaker_votes += Q.npr_r;
    } else {
        Q.empty_speaker_votes += Q.npr_r;
    }
    if (Q.pschd_support_bbwr) {
        Q.bbwr_speaker_votes += Q.pschd_r;
    } else {
        Q.empty_speaker_votes += Q.pschd_r;
    }
    if (Q.pslp_support_bbwr) {
        Q.bbwr_speaker_votes += Q.pslp_r;
    } else {
        Q.empty_speaker_votes += Q.pslp_r;
    }
} else if (Q.bbwr_support_pps) {
    Q.pps_speaker_votes += Q.bbwr_r;
    Q.pps_speaker_votes += Q.pslw_r;
    Q.pps_speaker_votes += Q.sch_r;
    Q.minorities_speaker_votes -= Q.other_r;
    Q.pps_speaker_votes += Q.other_votes;
    Q.sn_speaker_votes += Q.pschd_votes;
    Q.sn_speaker_votes += Q.npr_votes;
    Q.sn_speaker_votes += Q.pslp_votes;
} else {
    Q.sn_speaker_votes += Q.bbwr_votes;
    Q.sn_speaker_votes += Q.pschd_votes;
    Q.sn_speaker_votes += Q.pslw_votes;
    Q.sn_speaker_votes += Q.pslp_votes;
    Q.pps_speaker_votes += Q.kpp_votes;
}
if (Q.other_support_pps) {
    Q.sn_speaker_votes -= Q.owp_votes;
    Q.sn_speaker_votes += Q.owp_votes;
}

if (Q.hindenburg_to_braun_bonus) {
    Q.sn_speaker_votes -= Q.hindenburg_to_braun_bonus;
    Q.bbwr_speaker_votes += Q.hindenburg_to_braun_bonus;
}
if (Q.thalmann_to_braun_bonus) {
    Q.pps_speaker_votes -= Q.thalmann_to_braun_bonus;
    Q.bbwr_speaker_votes += Q.thalmann_to_braun_bonus;
}

// check for majority
Q.bbwr_speaker_majority = (Q.bbwr_speaker_votes >= 50);
Q.pps_speaker_majority = (Q.pps_speaker_votes >= 50);
Q.sn_speaker_majority = (Q.sn_votes >= 50);
Q.any_majority = Q.bbwr_speaker_majority | Q.pps_speaker_majority | Q.sn_speaker_majority

// check for plurality
Q.bbwr_speaker_plurality = (Q.bbwr_speaker_votes >= Q.sn_speaker_votes && Q.bbwr_speaker_votes >= Q.pps_speaker_votes);
Q.pps_plurality = (Q.pps_speaker_votes >= Q.sn_speaker_votes && Q.pps_speaker_votes >= Q.bbwr_speaker_votes);
Q.sn_plurality = (Q.sn_speaker_votes >= Q.pps_speaker_votes && Q.sn_speaker_votes >= Q.bbwr_speaker_votes);

// If no candidate gets above 50%, then there's a second round. In the second round, a plurality wins. 
Q.election_round += 1;
!}
go-to: bbwr_speaker_wins if bbwr_speaker_majority == 1; pps_speaker_wins if pps_speaker_majority == 1; sn_speaker_wins if sn_speaker_majority == 1; no_majority_round1 if any_majority == 0 and election_round == 1; round2_results if election_round >= 2

