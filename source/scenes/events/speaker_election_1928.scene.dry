on-arrival: {!
Q.pps_support_bbwr = 0;

if (Q.pschd_relation >= 55) {
    Q.pps_support_bbwr = 1;
    if (Q.other_support_pps) {
        Q.hindenburg_to_braun_bonus += Math.round(Q.other_votes/2);
    }
} else if (Q.pschd_relation >= 50 && Q.other_support_pps) {
    Q.pps_support_bbwr = 1;
    Q.hindenburg_to_braun_bonus += Math.round(Q.other_votes/2);
} else if (Q.pschd_relation <= 35) {
    Q.pps_support_bbwr = 0;
} else {
    Q.pps_support_bbwr = 2;
}
!}
