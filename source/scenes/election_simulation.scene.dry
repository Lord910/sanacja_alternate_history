Q.klasa_srednia_mniejszosci = 0;
Q.klasa_srednia_npr = 10;
Q.klasa_srednia_pps = 10;
Q.klasa_srednia_pschd = 20;
Q.klasa_srednia_pslp = 5;
Q.klasa_srednia_pslw = 10;
Q.klasa_srednia_sch = 0;
Q.klasa_srednia_zln = 20;

// Poparcie dla partii wśród klasy wyższej
