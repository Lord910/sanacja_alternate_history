title: Election Simulation
set-jump: post_election


- @1928: 1928 historical scenario
- @1930: 1930 historical scenario
- @1932: 1932 (July) historical scenario

@1928
on-arrival: {!
Q.chlopi = 55; // chłopi
Q.robotnicy = 27.5; // robotnicy
Q.klasa_srednia = 16; // drobnomieszczaństwo, inteligencja, klasa_srednia i wolne zawody
Q.klasa_wyzsza = 1.4; // więksi przedsiębiorcy i ziemianie
Q.bezrobotni = 8.6; // bezrobotni
Q.mniejszosci = 32; // mniejszości narodowe (Polacy stanowili 68% ogółu obywateli)

Q.classes = ['robotnicy', 'klasa_wyzsza', 'klasa_srednia', 'chlopi', 'bezrobotni', 'mniejszosci'];
Q.parties = ['bbwr', 'kpp', 'pschd', 'pslw', 'pslp', 'sn', 'owp', 'other', 'pps', 'npr', 'sch'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
// Poparcie dla partii wśród chłopów
Q.chlopi_bbwr = 10;
Q.chlopi_kpp = 5;
Q.chlopi_mniejszosci = 0;
Q.chlopi_npr = 5;
Q.chlopi_pps = 5;
Q.chlopi_pschd = 5;
Q.chlopi_pslp = 20;
