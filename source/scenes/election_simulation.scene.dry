title: Election Simulation
set-jump: post_election


- @1928: 1928 historical scenario
- @1930: 1930 historical scenario
- @1932: 1932 (July) historical scenario

@1928
on-arrival: {!
Q.workers = 46; // industry and trade
Q.old_middle = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.new_middle = 14; // "new mittelstand"
Q.rural = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.unemployed = 8.6;
Q.catholics = 30;

Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployed', 'catholics'];
Q.parties = ['spd', 'kpp', 'z', 'psl-w', 'npr', 'sn', 'owp', 'other'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
Q.workers_spd = 65;
Q.workers_kpp = 20;
Q.workers_z = 5;
Q.workers_psl-w = 0;
Q.workers_npr = 0;
Q.workers_sn = 5;
Q.workers_owp = 0;
Q.workers_other = 10;

Q.old_middle_spd = 5;
Q.old_middle_kpp = 0;
Q.old_middle_z = 5;
Q.old_middle_psl-w= 10;
Q.old_middle_npr = 25;
Q.old_middle_sn = 25;
Q.old_middle_owp = 10;
Q.old_middle_other = 10;

Q.new_middle_spd = 5;
Q.new_middle_kpp = 0;
Q.new_middle_z = 10;
Q.new_middle_psl-w= 25;
Q.new_middle_npr = 25;
Q.new_middle_sn = 10;
Q.new_middle_owp = 5;
Q.new_middle_other = 15;

Q.rural_spd = 10;
Q.rural_kpp = 0;
Q.rural_z = 5;
Q.rural_psl-w= 5;
Q.rural_npr = 15;
Q.rural_sn = 45;
Q.rural_owp = 5;
Q.rural_other = 10;

Q.unemployed_spd = 25;
Q.unemployed_kpp = 55;
Q.unemployed_z = 1;
Q.unemployed_psl-w = 0;
Q.unemployed_npr = 0;
Q.unemployed_sn = 5;
Q.unemployed_owp = 15;
Q.unemployed_other = 9;

Q.catholics_spd = 15;
Q.catholics_kpp = 5;
Q.catholics_z = 50;
Q.catholics_psl-w = 0;
Q.catholics_npr = 5;
Q.catholics_sn = 5;
Q.catholics_owp = 0;
Q.catholics_other = 10;
!}
go-to: election_algorithm
set-jump: post_election

