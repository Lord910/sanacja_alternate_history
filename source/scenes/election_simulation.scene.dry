Q.klasa_wyzsza_mniejszosci = 0;
Q.klasa_wyzsza_npr = 10;
Q.klasa_wyzsza_pps = 5;
Q.klasa_wyzsza_pschd = 20;
Q.klasa_wyzsza_pslp = 5;
Q.klasa_wyzsza_pslw = 10;
Q.klasa_wyzsza_sch = 0;
Q.klasa_wyzsza_zln = 20;

// Poparcie dla partii wśród bezrobotnych
Q.bezrobotni_bbwr = 10;
Q.bezrobotni_kpp = 30;
Q.bezrobotni_mniejszosci = 0;
Q.bezrobotni_npr = 10;
Q.bezrobotni_pps = 30;
Q.bezrobotni_pschd = 5;
Q.bezrobotni_pslp = 0;
Q.bezrobotni_pslw = 5;
