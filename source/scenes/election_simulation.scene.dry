title: Election Simulation
set-jump: post_election


- @1928: 1928 historical scenario
- @1930: 1930 historical scenario
- @1932: 1932 (July) historical scenario

@1928
on-arrival: {!
Q.workers = 46; // industry and trade
Q.old_middle = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.new_middle = 14; // "new mittelstand"
Q.rural = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.unemployed = 8.6;
Q.catholics = 30;

Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'unemployed', 'catholics'];
Q.parties = ['bbwr', 'kpp', 'pschd', 'pslw', 'pslp', 'sn', 'owp', 'other', 'pps', 'npr'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
Q.workers_bbwr = 65;
Q.workers_kpp = 20;
Q.workers_pschd = 5;
Q.workers_pslw = 0;
Q.workers_pslp = 0;
Q.workers_sn = 5;
Q.workers_owp = 0;
Q.workers_other = 10;

Q.old_middle_bbwr = 5;
Q.old_middle_kpp = 0;
Q.old_middle_pschd = 5;
Q.old_middle_pslw= 10;
Q.old_middle_pslp = 25;
Q.old_middle_sn = 25;
Q.old_middle_owp = 10;
Q.old_middle_other = 10;

Q.new_middle_bbwr = 5;
Q.new_middle_kpp = 0;
Q.new_middle_pschd = 10;
Q.new_middle_pslw= 25;
Q.new_middle_pslp = 25;
Q.new_middle_sn = 10;
Q.new_middle_owp = 5;
Q.new_middle_other = 15;

Q.rural_bbwr = 10;
Q.rural_kpp = 0;
Q.rural_pschd = 5;
Q.rural_pslw= 5;
Q.rural_pslp = 15;
Q.rural_sn = 45;
Q.rural_owp = 5;
Q.rural_other = 10;

Q.unemployed_bbwr = 25;
Q.unemployed_kpp = 55;
Q.unemployed_pschd = 1;
Q.unemployed_pslw = 0;
Q.unemployed_pslp = 0;
Q.unemployed_sn = 5;
Q.unemployed_owp = 15;
Q.unemployed_other = 9;

Q.catholics_bbwr = 15;
Q.catholics_kpp = 5;
Q.catholics_pschd = 50;
Q.catholics_pslw = 0;
Q.catholics_pslp = 5;
Q.catholics_sn = 5;
Q.catholics_owp = 0;
Q.catholics_other = 10;
!}
go-to: election_algorithm
set-jump: post_election

