title: Root Scene
new-page: true
go-to: post_event if started = 1; start_menu if started = 0

# TODO: do that thing that we did before...

@start_menu
new-page: true
go-to: start_menu_2

= Sanacja: An Alternate History

@start_menu_2

<div style="width: 400px; margin: 0 auto; padding: 20px; color: #000000; border-radius: 10px; font-family: Arial, sans-serif;">
    <h1 style="font-size: 24px; text-align: center; margin-bottom: 20px;">Republic of Poland</h1>
    <div style="text-align: center; margin-bottom: 20px;">
    <img src="img/CoA.png" alt="Flag of Poland" style="width: auto; height: 250px;">
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span style="font-weight: bold;">Government:</span>
        <span>Semi-Presidential Republic</span>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span style="font-weight: bold;">Population:</span>
        <span>30 million</span>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span style="font-weight: bold;">Economy:</span>
        <span>Recovering</span>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span style="font-weight: bold;">Military:</span>
        <span>Regional Power</span>
    </div>
    <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
        <span style="font-weight: bold;">Starting Date:</span>
        <span>January 1st 1928</span>
    </div>
    <div style="text-align: center; margin-top: 20px;">
        <p>Almost 2 years have passed since 1926 May Coup.<br />The government of Józef Piłsudski is preparing for upcoming elections.</p>
    </div>
</div>

- @start: Start game
- @game_over.achievements


@start
on-arrival: {!
Q.started = 1;
// time elapsed (in months)
Q.time = 1;
Q.year = 1928;
Q.month = 1;
// how many actions have been taken this month?
Q.month_actions = 0;

// 0 = normal difficulty, 1 = hard mode, 2 = hard mode no saves
Q.difficulty = 0;
Q.historical_mode = 0;
// old demographics
Q.old_demographics = 0;

// party resources
Q.resources = 2;
// party dues
Q.dues = 2;

// the state of the party
// overall dissent reduces every increase in party support.
Q.dissent = 0.05;
Q.dissent_percent = 5;

// factions
Q.factions = ['repairers', 'liberals', 'sanacja_left', 'colonels', 'conservatives', 'fourth_brigade'];
// should this be normalized to 100%?
Q.repairers_strength = 15;
Q.repairers_dissent = 15;
Q.liberals_strength = 20;
Q.liberals_dissent = 10;
Q.sanacja_left_strength = 10;
Q.sanacja_left_dissent = 10;
Q.colonels_strength = 25;
Q.colonels_dissent = 0;
Q.conservatives_strength = 15;
Q.conservatives_dissent = 10;
Q.fourth_brigade_strength = 15;
Q.fourth_brigade_dissent = 15;

// secret events...
